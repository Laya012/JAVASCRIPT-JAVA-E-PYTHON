import java.time.LocalTime;
import java.time.LocalDate;
import java.time.Period;

public class VerificarAcesso {
    public static void main(String[] args) {
        
        String nome = "Aylan";
        int diaNasc = 12;
        int mesNasc = 01;
        int anoNasc = 2010;
        
        LocalDate hoje = LocalDate.now();
        LocalTime agora = LocalTime.now();
        
        LocalDate dataNasc = LocalDate.of(anoNasc, mesNasc, diaNasc);
        int idade = Period.between(dataNasc, hoje).getYears();
        
        int hora = agora.getHour();
        
        String cumprimento;
        if (hora >= 5 && hora < 12) {
            cumprimento = "BOM DIA";
        } else if (hora >= 12 && hora < 18) {
            cumprimento = "BOA TARDE";
        } else if (hora >= 18 && hora < 23) {
            cumprimento = "BOA NOITE";
        } else {
            cumprimento = "BOA MADRUGADA";
        }
        
        boolean maiorIdade = idade >= 18;
        
        // MOSTRA OS RESULTADOS
        System.out.println("=================================");
        System.out.println("       DADOS DO USUÁRIO");
        System.out.println("=================================");
        System.out.println("Nome: " + nome);
        System.out.println("Nascimento: " + diaNasc + "/" + mesNasc + "/" + anoNasc);
        System.out.println("Idade: " + idade + " anos");
        System.out.println("Hora atual: " + agora.getHour() + ":" + String.format("%02d", agora.getMinute()));
        System.out.println("Cumprimento: " + cumprimento + ", " + nome.split(" ")[0] + "!");
        System.out.println("---------------------------------");
        
        if (maiorIdade) {
            System.out.println("✅ ACESSO LIBERADO");
        } else {
            System.out.println("❌ ACESSO NEGADO - Menor de idade");
            System.out.println("Faltam " + (18 - idade) + " anos");
        }
        System.out.println("=================================");
    }
}
