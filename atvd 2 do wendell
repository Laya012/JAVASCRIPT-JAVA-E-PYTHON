public class OperacoesCondicionais {
    public static void main(String[] args) {
        
        int num1 = 10;
        int num2 = 20;
        
        System.out.println("=== OPERAÇÕES CONDICIONAIS ===\n");
        System.out.println("Números: " + num1 + " e " + num2);
        System.out.println("-".repeat(30));
        
        if (num2 > num1) {
            int soma = num1 + num2;
            System.out.println("✅ " + num2 + " é maior que " + num1);
            System.out.println("➡️  Operação: SOMA");
            System.out.println(num1 + " + " + num2 + " = " + soma);
            
        } else if (num1 > num2) {
            int subtracao = num1 - num2;
            System.out.println("✅ " + num1 + " é maior que " + num2);
            System.out.println("➡️  Operação: SUBTRAÇÃO");
            System.out.println(num1 + " - " + num2 + " = " + subtracao);
            
        } else {
            System.out.println("⚠️  Os números são IGUAIS");
            System.out.println(num1 + " = " + num2);
        }
        
        System.out.println("-".repeat(30));
    }
}

