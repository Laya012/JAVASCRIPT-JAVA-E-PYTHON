import java.util.Calendar;

public class SaudacaoCalendar {
    public static void main(String[] args) {
        Calendar calendario = Calendar.getInstance();
        int hora = calendario.get(Calendar.HOUR_OF_DAY); 
        int minuto = calendario.get(Calendar.MINUTE);
        
        System.out.println("⏰ Hora atual: " + hora + ":" + String.format("%02d", minuto));
        System.out.print("👉 ");
        if (hora >= 5 && hora < 12) {
            System.out.println("🌅 BOM DIA! Tenha um ótimo dia!");
        } else if (hora >= 12 && hora < 18) {
            System.out.println("☀️ BOA TARDE! Como está seu dia?");
        } else if (hora >= 18 && hora < 23) {
            System.out.println("🌙 BOA NOITE! Descanse bem!");
        } else {
            System.out.println("VAI DORMIR! Já passou da hora! (entre 23h e 5h)");
        }
    }
}

